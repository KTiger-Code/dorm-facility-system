---
title: Flowchart - กระบวนการเปลี่ยนรหัสผ่าน
---
flowchart TD
    A([เปิดหน้าเปลี่ยนรหัสผ่าน]) --> B[กรอก รหัสผ่านเดิม]
    B --> C[กรอก รหัสผ่านใหม่]
    C --> D[กรอก ยืนยันรหัสผ่านใหม่]
    D --> E{ตรวจสอบ<br/>ฝั่ง Client}

    E -- "รหัสใหม่ < 6 ตัว" --> F[แสดง Error:<br/>ต้องมีอย่างน้อย 6 ตัวอักษร]
    F --> C
    E -- "รหัสใหม่ ≠ ยืนยัน" --> G[แสดง Error:<br/>รหัสผ่านไม่ตรงกัน]
    G --> D
    E -- "รหัสใหม่ = รหัสเดิม" --> H[แสดง Error:<br/>ต้องไม่ซ้ำกับรหัสเดิม]
    H --> C
    E -- ผ่าน --> I[กดปุ่ม บันทึกรหัสผ่านใหม่]

    I --> J["PATCH /api/users/change-password"]
    J --> K{Server ตรวจสอบ<br/>รหัสเดิม}
    K -- "bcrypt.compare ไม่ตรง" --> L[แสดง Error:<br/>รหัสผ่านเดิมไม่ถูกต้อง]
    L --> B
    K -- ถูกต้อง --> M["bcrypt.hash(new_password)"]
    M --> N[UPDATE users SET password]
    N --> O[แสดง: เปลี่ยนรหัสผ่านสำเร็จ!]
    O --> P["รอ 2 วินาที"]
    P --> Q[ลบ Token จาก localStorage]
    Q --> R[Redirect ไป /login]
    R --> S([จบ — Login ใหม่ด้วยรหัสใหม่])
